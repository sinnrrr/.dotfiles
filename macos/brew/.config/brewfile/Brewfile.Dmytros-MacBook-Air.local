
# tap repositories and their packages

tap 'homebrew/core'
brew 'biome'
brew 'exiftool'
brew 'ffmpeg'
brew 'git-delta'
brew 'jq'
brew 'libarchive'
brew 'lua'
brew 'luajit'
brew 'mas'
brew 'mergiraf'
brew 'poppler'
brew 'rust'
brew 'speedtest-cli'

tap 'homebrew/cask'
cask 'claude-code'
cask 'gimp'
cask 'google-chrome'
cask 'google-drive'
cask 'insta360-studio'
cask 'orbstack'
cask 'quarto'
cask 'rawtherapee'
cask 'readdle-spark'

tap 'mhaeuser/mhaeuser'

tap 'nikitabobko/tap'

tap 'raine/claude-history'

tap 'rcmdnk/file'

tap 'walavave/tap'
