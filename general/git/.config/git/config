[includeIf "gitdir:/Users/sinnrrr/"]
	path = ~/.config/git/.gitconfig.personal

[includeIf "gitdir:/Users/dmytro.soltysiuk.-nd/"]
	path = ~/.config/git/.gitconfig.work

[includeIf "gitdir:~/.dotfiles/"]
	path = ~/.config/git/.gitconfig.personal

[includeIf "gitdir:~/.dotfiles/work/"]
	path = ~/.config/git/.gitconfig.work

[includeIf "gitdir:/opt/homebrew/"]
	path = ~/.config/git/.gitconfig.work

[core]
	ignorecase = false
[push]
	autoSetupRemote = true
[pull]
	rebase = true
[delta]
	syntax-theme = "Catppuccin Mocha"
[merge]
	conflictStyle = diff3
[merge "mergiraf"]
	name = mergiraf
	driver = mergiraf merge --git %O %A %B -p %P -l %L
[rebase]
	autoStash = true
	committerDateIsAuthorDate = true
[init]
	defaultBranch = main
